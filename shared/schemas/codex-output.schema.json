{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodexScreenAnalysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "key_points",
    "ocr_text",
    "answer",
    "next_actions",
    "uncertainties"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "key_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ocr_text": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "answer": {
      "type": "string"
    },
    "next_actions": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
